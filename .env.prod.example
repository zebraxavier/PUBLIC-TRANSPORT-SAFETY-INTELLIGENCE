# Production Environment Template
# Copy this to .env and fill in actual values

# Backend (Node.js)
PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb://admin:password@mongodb:27017/ptsi_db?authSource=admin
REDIS_URL=redis://:password@redis:6379
JWT_SECRET=your_long_random_secret_key_here_minimum_32_chars
AI_SERVICE_URL=http://ai-service:8000
WS_PORT=5001
AI_WORKER_CONCURRENCY=8

# Frontend (React)
VITE_API_URL=https://api.yourdomain.com
VITE_WS_URL=wss://api.yourdomain.com/ws

# AI Service (Python)
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=https://yourdomain.com

# Database
MONGO_USER=admin
MONGO_PASSWORD=change_me_to_secure_password
REDIS_PASSWORD=change_me_to_secure_password

# SMTP (for email alerts in future)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=app_specific_password

# Monitoring & Logging
SENTRY_DSN=https://your_sentry_key@sentry.io/project_id
LOG_LEVEL=info

# SSL/TLS (for HTTPS)
SSL_CERT_PATH=/etc/ssl/certs/yourdomain.com.crt
SSL_KEY_PATH=/etc/ssl/private/yourdomain.com.key
